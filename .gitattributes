# Auto detect text files and perform LF normalization
* text=auto

# These files are text and should be normalized (convert crlf => lf)
*.css        text
*.html       text
*.js         text
*.json       text
*.md         text
*.ts         text
*.tsx        text
*.yml        text
*.yaml       text

# These files are binary and should not be modified
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.mov        binary
*.mp4        binary
*.mp3        binary
*.flv        binary
*.fla        binary
*.swf        binary
*.pdf        binary
